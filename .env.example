# Variables publiques cote client
VITE_API_BASE_URL=
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here
# Observabilite client (optionnel) - laisser vide pour desactiver Sentry
VITE_SENTRY_DSN=
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES=0

# Variables backend serverless
ALLOWED_ORIGIN=https://your-app.example.com
ANTHROPIC_API_KEY=sk-ant-...
VAPID_PRIVATE_KEY=your_vapid_private_key_here
SUPERADMIN_PASSWORD_HASH=$2b$10$replace_with_a_bcrypt_hash
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"citadelle-school","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-...@citadelle-school.iam.gserviceaccount.com","client_id":"..."}
APP_FUNCTION_REGION=europe-west1
# Observabilite serveur (optionnel) - laisser vide pour desactiver Sentry
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES=0
# Pour le panneau "Alertes" du SuperAdmin (liste des issues + bouton test).
# SENTRY_AUTH_TOKEN doit avoir le scope `event:read` + `project:read`.
SENTRY_AUTH_TOKEN=
SENTRY_ORG_SLUG=
SENTRY_PROJECT_SLUG=
