rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function planFields() {
      return ["plan", "planExpiry", "planActivatedBy", "planActivatedAt", "lastSuccessfulPaymentId"];
    }

    function tokenRole() {
      return request.auth != null && request.auth.token.role is string
        ? request.auth.token.role
        : null;
    }

    function tokenSchoolId() {
      return request.auth != null && request.auth.token.schoolId is string
        ? request.auth.token.schoolId
        : null;
    }

    function appartientEcole(schoolId) {
      return request.auth != null && (
        (tokenSchoolId() != null && tokenSchoolId() == schoolId) ||
        (tokenSchoolId() == null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId)
      );
    }

    function roleUtilisateur() {
      return request.auth != null
        ? (tokenRole() != null
            ? tokenRole()
            : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role)
        : null;
    }

    function aUnRole(roles) {
      return request.auth != null && [roleUtilisateur()].hasAny(roles);
    }

    function backOfficeRoles() {
      return ["direction", "admin", "primaire", "college", "comptable"];
    }

    // Rôles autorisés à écrire côté client. L'admin est retiré : il est en
    // lecture seule pour empêcher tout contournement de l'UI via un client
    // Firestore direct (console, SDK, etc.).
    function backOfficeWriteRoles() {
      return ["direction", "primaire", "college", "comptable"];
    }

    function pedagogieRoles(sectionRole) {
      return ["direction", "admin", sectionRole];
    }

    function pedagogieWriteRoles(sectionRole) {
      return ["direction", sectionRole];
    }

    function messageParentValide(schoolId) {
      return appartientEcole(schoolId)
             && aUnRole(["parent"])
             && request.resource.data.expediteur == "parent"
             && request.resource.data.sujet is string
             && request.resource.data.sujet.size() > 0
             && request.resource.data.sujet.size() <= 200
             && request.resource.data.corps is string
             && request.resource.data.corps.size() > 0
             && request.resource.data.corps.size() <= 5000;
    }

    // Collections légitimes de l'application accessibles en lecture/écriture par le back-office.
    function collectionsBackOffice() {
      return [
        "evenements",
        "recettes",
        "depenses",
        "salaires",
        "bons",
        "personnel",
        "membres",
        "versements",
        "tarifs",
        "documents",
        "examens",
        "livrets",
        "elevesPrimaire",
        "elevesCollege",
        "elevesLycee",
        "classesPrimaire",
        "classesCollege",
        "classesLycee",
        "ensPrimaire",
        "ensCollege",
        "ensLycee",
        "ensPrimaire_enseignements",
        "ensCollege_enseignements",
        "ensLycee_enseignements",
        "classesPrimaire_emplois",
        "classesCollege_emplois",
        "classesLycee_emplois",
        "classesPrimaire_matieres",
        "classesCollege_matieres",
        "classesLycee_matieres"
      ];
    }

    match /ecoles/{schoolId} {
      allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);

      allow create: if aUnRole(["superadmin"])
                   && !request.resource.data.keys().hasAny(planFields());

      allow update: if aUnRole(["superadmin"])
                   || (appartientEcole(schoolId)
                       && aUnRole(["direction"])
                       && !request.resource.data.diff(resource.data).affectedKeys().hasAny(planFields()));

      allow delete: if false;

      match /comptes/{docId} {
        // Les comptes ne sont JAMAIS modifiables côté client.
        // Toute mutation passe par l'API serveur (Firebase Admin SDK)
        // qui applique les contrôles de rôle (canManageTargetRole) et
        // journalise dans audit_securite. Cela empêche un admin de
        // modifier directement le hash mdp d'un autre compte via un
        // client Firestore custom.
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin"]))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /audit_securite/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction"]))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /pushSubs/{docId} {
        allow read: if appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]);
        allow create, update, delete: if appartientEcole(schoolId);
      }

      match /paiements/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /annonces/{docId} {
        allow read: if true;
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /honneurs/{docId} {
        allow read: if true;
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /messages/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(backOfficeRoles()))
                     || aUnRole(["superadmin"]);
        allow create: if ((appartientEcole(schoolId) && aUnRole(backOfficeWriteRoles()))
                          || messageParentValide(schoolId)
                          || aUnRole(["superadmin"]));
        allow update, delete: if (appartientEcole(schoolId) && aUnRole(backOfficeWriteRoles()))
                               || aUnRole(["superadmin"]);
      }

      match /historique/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(backOfficeRoles()))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(backOfficeWriteRoles()))
                      || aUnRole(["superadmin"]);
      }

      match /demandes_plan/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]))
                     || aUnRole(["superadmin"]);
        allow create: if (appartientEcole(schoolId) && aUnRole(["direction", "comptable"]))
                       || aUnRole(["superadmin"]);
        allow update: if aUnRole(["superadmin"]);
        allow delete: if false;
      }

      match /notesCollege/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("college")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("college")))
                      || aUnRole(["superadmin"]);
      }

      match /notesPrimaire/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("primaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("primaire")))
                      || aUnRole(["superadmin"]);
      }

      match /notesLycee/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("college")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("college")))
                      || aUnRole(["superadmin"]);
      }

      match /elevesCollege_absences/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("college")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("college")))
                      || aUnRole(["superadmin"]);
      }

      match /elevesPrimaire_absences/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("primaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("primaire")))
                      || aUnRole(["superadmin"]);
      }

      match /elevesLycee_absences/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("college")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("college")))
                      || aUnRole(["superadmin"]);
      }

      match /appreciationsPrimaire/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("primaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("primaire")))
                      || aUnRole(["superadmin"]);
      }

      match /appreciationsCollege/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("college")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("college")))
                      || aUnRole(["superadmin"]);
      }

      match /appreciationsLycee/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(pedagogieRoles("college")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(pedagogieWriteRoles("college")))
                      || aUnRole(["superadmin"]);
      }

      // Catch-all durci : whitelist strict des collections légitimes de l'application.
      // Toute collection non listée ici est refusée en lecture ET en écriture.
      // L'admin peut LIRE (audit/lecture seule) mais NE PEUT PAS écrire :
      // c'est ce qui empêche un admin malveillant de contourner l'UI via
      // un client Firestore custom (console, SDK direct, etc.) pour
      // modifier recettes/dépenses/salaires/notes.
      match /{collection}/{docId} {
        allow read: if collection in collectionsBackOffice()
                    && ((appartientEcole(schoolId) && aUnRole(backOfficeRoles()))
                        || aUnRole(["superadmin"]));
        allow write: if collection in collectionsBackOffice()
                     && ((appartientEcole(schoolId) && aUnRole(backOfficeWriteRoles()))
                         || aUnRole(["superadmin"]));
      }
    }

    match /ecoles_public/{schoolId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /superadmins/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null && aUnRole(["superadmin"]);
    }

    match /transferts/{transfertId} {
      allow read, write: if false;
    }

    match /superadmin_messages/{messageId} {
      allow read: if request.auth != null && roleUtilisateur() != "parent";
      allow create, update, delete: if aUnRole(["superadmin"]);

      match /lectures/{uid} {
        allow read: if aUnRole(["superadmin"])
                     || (request.auth != null && request.auth.uid == uid);
        allow create: if request.auth != null
                       && request.auth.uid == uid
                       && roleUtilisateur() != "parent";
        allow update, delete: if false;
      }
    }

    match /{path=**}/demandes_plan/{docId} {
      allow read: if aUnRole(["superadmin"]);
      allow write: if false;
    }
  }
}
