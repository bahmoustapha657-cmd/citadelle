rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function planFields() {
      return ["plan", "planExpiry", "planActivatedBy", "planActivatedAt"];
    }

    function appartientEcole(schoolId) {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId;
    }

    function roleUtilisateur() {
      return request.auth != null
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function aUnRole(roles) {
      return request.auth != null && [roleUtilisateur()].hasAny(roles);
    }

    match /ecoles/{schoolId} {
      allow read: if true;

      // Création école : superadmin uniquement, sans champs plan
      allow create: if aUnRole(["superadmin"])
                   && !request.resource.data.keys().hasAny(planFields());

      // Mise à jour : superadmin peut tout modifier (plan inclus) ;
      // les autres membres peuvent modifier sauf les champs plan
      allow update: if aUnRole(["superadmin"])
                   || (appartientEcole(schoolId)
                       && !request.resource.data.diff(resource.data).affectedKeys().hasAny(planFields()));

      allow delete: if false;

      match /comptes/{docId} {
        allow read, write: if appartientEcole(schoolId) && aUnRole(["direction", "admin"]);
      }

      match /pushSubs/{docId} {
        allow read: if appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]);
        allow create: if appartientEcole(schoolId);
        allow update, delete: if appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]);
      }

      match /paiements/{docId} {
        allow read: if appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]);
        allow write: if false;
      }

      // Sous-collections générales : membres de l'école + superadmin
      match /{collection}/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
      }
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /superadmins/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null && aUnRole(["superadmin"]);
    }

    // Règle collection group pour les requêtes cross-écoles (superadmin)
    match /{path=**}/demandes_plan/{docId} {
      allow read: if aUnRole(["superadmin"]);
      allow write: if request.auth != null;
    }
  }

  // Transferts inter-écoles — readable par toute école authentifiée (via API)
  // La création/modification passe par l'API Vercel (firebase-admin, pas ces règles)
  match /transferts/{transfertId} {
    allow read: if request.auth != null;
    allow write: if false; // toujours via l'API serveur
  }
}
