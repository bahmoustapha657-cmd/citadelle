rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function planFields() {
      return ["plan", "planExpiry", "planActivatedBy", "planActivatedAt", "lastSuccessfulPaymentId"];
    }

    function tokenRole() {
      return request.auth != null && request.auth.token.role is string
        ? request.auth.token.role
        : null;
    }

    function tokenSchoolId() {
      return request.auth != null && request.auth.token.schoolId is string
        ? request.auth.token.schoolId
        : null;
    }

    function appartientEcole(schoolId) {
      return request.auth != null && (
        (tokenSchoolId() != null && tokenSchoolId() == schoolId) ||
        (tokenSchoolId() == null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId)
      );
    }

    function roleUtilisateur() {
      return request.auth != null
        ? (tokenRole() != null
            ? tokenRole()
            : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role)
        : null;
    }

    function aUnRole(roles) {
      return request.auth != null && [roleUtilisateur()].hasAny(roles);
    }

    // Perimetre dynamique de l'admin porte par le JWT. Le DG configure
    // roleSettings.admin.{modules,writeModules} dans AdminPanel ; le serveur
    // (account-manage:sync_role_settings) injecte ces listes dans les custom
    // claims. Defaut [] = aucun acces (admin a tokens legacy doit se
    // reloguer apres une resynchro DG).
    // Acces tolerant aux custom claims optionnels via map.get(key, default).
    // Firestore CEL || ne court-circuite pas : `aUnRole(...) || adminPeutLireModule(...)`
    // evalue les deux branches, donc on ne peut pas se permettre d'erreurer ici
    // quand l'admin n'a pas (encore) ses claims module — sinon meme direction
    // se retrouve refusee.
    function tokenAdminReadModules() {
      return request.auth == null
        ? []
        : request.auth.token.get("adminReadModules", []);
    }

    function tokenAdminWriteModules() {
      return request.auth == null
        ? []
        : request.auth.token.get("adminWriteModules", []);
    }

    function adminPeutLireModule(moduleId) {
      return tokenRole() == "admin" && tokenAdminReadModules().hasAny([moduleId]);
    }

    // Whitelist defensive synchrone avec ADMIN_WRITABLE_MODULES dans
    // shared/role-config.js. Meme si un claim ancien/forge contenait
    // adminWriteModules:["compta"], l'ecriture restera refusee.
    function adminWritableModules() {
      return ["primaire", "secondaire", "calendrier", "examens", "messages"];
    }

    function adminPeutEcrireModule(moduleId) {
      return tokenRole() == "admin"
        && adminWritableModules().hasAny([moduleId])
        && tokenAdminWriteModules().hasAny([moduleId]);
    }

    // Roles back-office HORS admin (l'admin transite par les helpers
    // adminPeutLireModule/adminPeutEcrireModule pour respecter son perimetre
    // configurable). Le DG configure son perimetre via roleSettings.admin.modules.
    function backOfficeRolesSansAdmin() {
      return ["direction", "primaire", "college", "comptable"];
    }

    // Roles autorises a ecrire cote client en dur (admin obtient l'ecriture
    // via adminPeutEcrireModule, par module, restreint a ADMIN_WRITABLE_MODULES
    // partage avec shared/role-config.js).
    function backOfficeWriteRolesSansAdmin() {
      return ["direction", "primaire", "college", "comptable"];
    }

    function pedagogieRolesSansAdmin(sectionRole) {
      return ["direction", sectionRole];
    }

    function pedagogieWriteRolesSansAdmin(sectionRole) {
      return ["direction", sectionRole];
    }

    function pushSubPayloadValide(uid) {
      return request.auth != null
             && request.auth.uid == uid
             && request.resource.data.keys().hasOnly(["subscription", "role", "nom", "uid", "updatedAt"])
             && request.resource.data.keys().hasAll(["subscription", "role", "uid", "updatedAt"])
             && request.resource.data.uid == request.auth.uid
             && request.resource.data.role == roleUtilisateur()
             && request.resource.data.subscription is map
             && request.resource.data.updatedAt is int
             && (!("nom" in request.resource.data) || request.resource.data.nom is string);
    }

    function messageParentValide(schoolId) {
      return appartientEcole(schoolId)
             && aUnRole(["parent"])
             && request.resource.data.expediteur == "parent"
             && request.resource.data.sujet is string
             && request.resource.data.sujet.size() > 0
             && request.resource.data.sujet.size() <= 200
             && request.resource.data.corps is string
             && request.resource.data.corps.size() > 0
             && request.resource.data.corps.size() <= 5000;
    }

    // Collections legitimes de l'application accessibles en lecture/ecriture par le back-office.
    function collectionsBackOffice() {
      return [
        "evenements",
        "recettes",
        "depenses",
        "salaires",
        "bons",
        "personnel",
        "membres",
        "versements",
        "tarifs",
        "documents",
        "examens",
        "livrets",
        "elevesPrimaire",
        "elevesCollege",
        "elevesLycee",
        "classesPrimaire",
        "classesCollege",
        "classesLycee",
        "ensPrimaire",
        "ensCollege",
        "ensLycee",
        "ensPrimaire_enseignements",
        "ensCollege_enseignements",
        "ensLycee_enseignements",
        "classesPrimaire_emplois",
        "classesCollege_emplois",
        "classesLycee_emplois",
        "classesPrimaire_matieres",
        "classesCollege_matieres",
        "classesLycee_matieres"
      ];
    }

    // Mapping collection -> module (catch-all). Doit rester synchrone avec
    // MODULE_COLLECTIONS dans shared/role-config.js.
    function moduleOfCollection(coll) {
      return ["recettes","depenses","salaires","bons","personnel","versements","tarifs"].hasAny([coll]) ? "compta"
           : ["elevesPrimaire","classesPrimaire","ensPrimaire","ensPrimaire_enseignements","classesPrimaire_emplois","classesPrimaire_matieres"].hasAny([coll]) ? "primaire"
           : ["elevesCollege","elevesLycee","classesCollege","classesLycee","ensCollege","ensLycee","ensCollege_enseignements","ensLycee_enseignements","classesCollege_emplois","classesLycee_emplois","classesCollege_matieres","classesLycee_matieres"].hasAny([coll]) ? "secondaire"
           : ["evenements"].hasAny([coll]) ? "calendrier"
           : ["examens","livrets"].hasAny([coll]) ? "examens"
           : ["membres","documents"].hasAny([coll]) ? "fondation"
           : "";
    }

    function adminPeutLireCollection(coll) {
      return adminPeutLireModule(moduleOfCollection(coll));
    }

    // Collections où SEUL le comptable peut écrire (le DG supervise, n'enregistre
    // pas). Le DG conserve l'autorisation via le verrou (toggleVerrou dans
    // AdminPanel) — ouvrir/fermer le verrou est réservé à direction via la
    // rule ecoles/{id} update.
    function isComptaCollection(coll) {
      return ["recettes","depenses","salaires","bons","personnel","versements","tarifs"].hasAny([coll]);
    }

    function adminPeutEcrireCollection(coll) {
      return adminPeutEcrireModule(moduleOfCollection(coll));
    }

    match /ecoles/{schoolId} {
      allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);

      allow create: if aUnRole(["superadmin"])
                   && !request.resource.data.keys().hasAny(planFields());

      // L'admin NE PEUT PAS modifier ecoles/{id} (module "parametres" est systeme).
      // Garde-fou anti-auto-promotion : sinon l'admin pourrait reecrire
      // roleSettings.admin.modules pour s'attribuer tous les droits.
      allow update: if aUnRole(["superadmin"])
                   || (appartientEcole(schoolId)
                       && aUnRole(["direction"])
                       && !request.resource.data.diff(resource.data).affectedKeys().hasAny(planFields()))
                   || (appartientEcole(schoolId)
                       && aUnRole(["comptable"])
                       && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["monnaie"]));

      allow delete: if false;

      // Profil légal officiel de l'établissement (arrêté d'agrément,
      // autorisation de création, codes statistiques, identité).
      // Lecture : tout rôle de l'école — utilisé en pied de bulletin /
      // attestation / certificat (donc tous les rôles imprimant un
      // document doivent pouvoir lire).
      // Écriture : direction/admin uniquement (pas de gating granulaire :
      // c'est un document d'identité juridique, pas un module métier).
      match /config/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin"]))
                      || aUnRole(["superadmin"]);
      }

      match /comptes/{docId} {
        // Les comptes ne sont JAMAIS modifiables cote client.
        // Toute mutation passe par l'API serveur (Firebase Admin SDK)
        // qui applique les controles de role (canManageTargetRole) et
        // journalise dans audit_securite.
        // Lecture : direction (toujours) + admin si "admin_panel" dans
        // adminReadModules (le DG peut retirer ce module a l'admin).
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(["direction"]) || adminPeutLireModule("admin_panel")))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /audit_securite/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction"]))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /pushSubs/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]))
                     || (appartientEcole(schoolId) && request.auth != null && request.auth.uid == docId);
        allow create: if appartientEcole(schoolId) && pushSubPayloadValide(docId);
        allow update: if appartientEcole(schoolId)
                       && resource.data.uid == request.auth.uid
                       && pushSubPayloadValide(docId);
        allow delete: if appartientEcole(schoolId)
                       && request.auth != null
                       && request.auth.uid == docId
                       && resource.data.uid == request.auth.uid;
      }

      match /paiements/{docId} {
        // Finance : admin doit avoir "compta" dans adminReadModules.
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(["direction", "comptable"]) || adminPeutLireModule("compta")))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /annonces/{docId} {
        allow read: if true;
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /honneurs/{docId} {
        allow read: if true;
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /messages/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(backOfficeRolesSansAdmin()) || adminPeutLireModule("messages")))
                     || aUnRole(["superadmin"]);
        allow create: if ((appartientEcole(schoolId)
                            && (aUnRole(backOfficeWriteRolesSansAdmin()) || adminPeutEcrireModule("messages")))
                          || messageParentValide(schoolId)
                          || aUnRole(["superadmin"]));
        allow update, delete: if (appartientEcole(schoolId)
                                   && (aUnRole(backOfficeWriteRolesSansAdmin()) || adminPeutEcrireModule("messages")))
                               || aUnRole(["superadmin"]);
      }

      match /historique/{docId} {
        // Journal d'audit : admin peut lire si module "historique" coche par DG,
        // mais "historique" n'est PAS dans ADMIN_WRITABLE_MODULES cote shared/
        // role-config.js, donc adminPeutEcrireModule("historique") = false
        // par construction. Garde-fou anti-effacement-de-traces.
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(backOfficeRolesSansAdmin()) || adminPeutLireModule("historique")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(backOfficeWriteRolesSansAdmin()))
                      || aUnRole(["superadmin"]);
      }

      match /demandes_plan/{docId} {
        // Lie au module "parametres" (plan = parametre d'ecole) : admin lit
        // si DG l'autorise. Creation reservee direction/comptable cote client.
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(["direction", "comptable"]) || adminPeutLireModule("parametres")))
                     || aUnRole(["superadmin"]);
        allow create: if (appartientEcole(schoolId) && aUnRole(["direction", "comptable"]))
                       || aUnRole(["superadmin"]);
        allow update: if aUnRole(["superadmin"]);
        allow delete: if false;
      }

      match /notesCollege/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("college")) || adminPeutLireModule("secondaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("college")) || adminPeutEcrireModule("secondaire")))
                      || aUnRole(["superadmin"]);
      }

      match /notesPrimaire/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("primaire")) || adminPeutLireModule("primaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("primaire")) || adminPeutEcrireModule("primaire")))
                      || aUnRole(["superadmin"]);
      }

      match /notesLycee/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("college")) || adminPeutLireModule("secondaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("college")) || adminPeutEcrireModule("secondaire")))
                      || aUnRole(["superadmin"]);
      }

      match /elevesCollege_absences/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("college")) || adminPeutLireModule("secondaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("college")) || adminPeutEcrireModule("secondaire")))
                      || aUnRole(["superadmin"]);
      }

      match /elevesPrimaire_absences/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("primaire")) || adminPeutLireModule("primaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("primaire")) || adminPeutEcrireModule("primaire")))
                      || aUnRole(["superadmin"]);
      }

      match /elevesLycee_absences/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("college")) || adminPeutLireModule("secondaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("college")) || adminPeutEcrireModule("secondaire")))
                      || aUnRole(["superadmin"]);
      }

      match /appreciationsPrimaire/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("primaire")) || adminPeutLireModule("primaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("primaire")) || adminPeutEcrireModule("primaire")))
                      || aUnRole(["superadmin"]);
      }

      match /appreciationsCollege/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("college")) || adminPeutLireModule("secondaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("college")) || adminPeutEcrireModule("secondaire")))
                      || aUnRole(["superadmin"]);
      }

      match /appreciationsLycee/{docId} {
        allow read: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieRolesSansAdmin("college")) || adminPeutLireModule("secondaire")))
                     || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId)
                        && (aUnRole(pedagogieWriteRolesSansAdmin("college")) || adminPeutEcrireModule("secondaire")))
                      || aUnRole(["superadmin"]);
      }

      // Catch-all durci : whitelist stricte des collections legitimes de l'application.
      // Toute collection non listee ici est refusee en lecture ET en ecriture.
      // L'admin dispose d'un acces par module (claims adminReadModules /
      // adminWriteModules portes par le JWT). Sans entree dans
      // moduleOfCollection(), l'admin est refuse en lecture comme en ecriture.
      //
      // Cas particulier compta : recettes/depenses/salaires/bons/personnel/
      // versements/tarifs ne sont ecrits QUE par le comptable (+ superadmin).
      // Le DG supervise et controle l'ouverture du verrou (cf. toggleVerrou
      // dans AdminPanel), mais ne saisit pas lui-meme.
      match /{collection}/{docId} {
        allow read: if collection in collectionsBackOffice()
                    && ((appartientEcole(schoolId)
                          && (aUnRole(backOfficeRolesSansAdmin()) || adminPeutLireCollection(collection)))
                        || aUnRole(["superadmin"]));
        allow write: if collection in collectionsBackOffice()
                     && ((appartientEcole(schoolId)
                           && (
                             (isComptaCollection(collection)
                               ? aUnRole(["comptable"])
                               : aUnRole(backOfficeWriteRolesSansAdmin()))
                             || adminPeutEcrireCollection(collection)
                           ))
                         || aUnRole(["superadmin"]));
      }
    }

    match /ecoles_public/{schoolId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /superadmins/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null && aUnRole(["superadmin"]);
    }

    match /transferts/{transfertId} {
      allow read, write: if false;
    }

    match /superadmin_messages/{messageId} {
      allow read: if aUnRole(["superadmin"]);
      allow create, update, delete: if aUnRole(["superadmin"]);

      match /lectures/{uid} {
        allow read: if aUnRole(["superadmin"])
                     || (request.auth != null && request.auth.uid == uid);
        allow create: if request.auth != null
                       && request.auth.uid == uid
                       && roleUtilisateur() != "parent";
        allow update, delete: if false;
      }
    }

    match /{path=**}/demandes_plan/{docId} {
      allow read: if aUnRole(["superadmin"]);
      allow write: if false;
    }
  }
}
