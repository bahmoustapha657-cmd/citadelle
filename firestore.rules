rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function planFields() {
      return ["plan", "planExpiry", "planActivatedBy", "planActivatedAt", "lastSuccessfulPaymentId"];
    }

    function allowedSchoolRoles() {
      return ["direction", "admin", "primaire", "college", "comptable", "enseignant", "parent"];
    }

    function tokenRole() {
      return request.auth != null && request.auth.token.role is string
        ? request.auth.token.role
        : null;
    }

    function tokenSchoolId() {
      return request.auth != null && request.auth.token.schoolId is string
        ? request.auth.token.schoolId
        : null;
    }

    function appartientEcole(schoolId) {
      return request.auth != null && (
        (tokenSchoolId() != null && tokenSchoolId() == schoolId) ||
        (tokenSchoolId() == null &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.schoolId == schoolId)
      );
    }

    function roleUtilisateur() {
      return request.auth != null
        ? (tokenRole() != null
            ? tokenRole()
            : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role)
        : null;
    }

    function aUnRole(roles) {
      return request.auth != null && [roleUtilisateur()].hasAny(roles);
    }

    function roleScolaireValide(role) {
      return role is string && [role].hasAny(allowedSchoolRoles());
    }

    function compteAllowedKeys() {
      return [
        "login",
        "mdp",
        "role",
        "label",
        "nom",
        "eleveId",
        "eleveNom",
        "eleveClasse",
        "section",
        "matiere",
        "premiereCo",
        "statut",
        "createdAt",
        "updatedAt",
        "enseignantNom",
        "uid"
      ];
    }

    function compteCreateValide() {
      return request.resource.data.keys().hasOnly(compteAllowedKeys())
             && !request.resource.data.keys().hasAny(["uid"])
             && request.resource.data.login is string
             && request.resource.data.login.size() >= 3
             && request.resource.data.login.size() <= 30
             && request.resource.data.mdp is string
             && request.resource.data.mdp.size() >= 20
             && roleScolaireValide(request.resource.data.role);
    }

    function compteAdminUpdateValide() {
      return request.resource.data.keys().hasOnly(compteAllowedKeys())
             && request.resource.data.login == resource.data.login
             && request.resource.data.uid == resource.data.uid
             && request.resource.data.mdp is string
             && request.resource.data.mdp.size() >= 20
             && roleScolaireValide(request.resource.data.role);
    }

    match /ecoles/{schoolId} {
      allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);

      allow create: if aUnRole(["superadmin"])
                   && !request.resource.data.keys().hasAny(planFields());

      allow update: if aUnRole(["superadmin"])
                   || (appartientEcole(schoolId)
                       && aUnRole(["direction", "admin"])
                       && !request.resource.data.diff(resource.data).affectedKeys().hasAny(planFields()));

      allow delete: if false;

      match /comptes/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin"]))
                     || aUnRole(["superadmin"]);
        allow create: if (appartientEcole(schoolId) && aUnRole(["direction", "admin"]) && compteCreateValide())
                       || aUnRole(["superadmin"]);
        allow update: if (appartientEcole(schoolId) && aUnRole(["direction", "admin"]) && compteAdminUpdateValide())
                       || aUnRole(["superadmin"]);
        allow delete: if (appartientEcole(schoolId) && aUnRole(["direction", "admin"]))
                       || aUnRole(["superadmin"]);
      }

      match /pushSubs/{docId} {
        allow read: if appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]);
        allow create, update, delete: if appartientEcole(schoolId);
      }

      match /paiements/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]))
                     || aUnRole(["superadmin"]);
        allow write: if false;
      }

      match /annonces/{docId} {
        allow read: if true;
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /honneurs/{docId} {
        allow read: if true;
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /messages/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable", "primaire", "college", "parent"]))
                      || aUnRole(["superadmin"]);
      }

      match /historique/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }

      match /demandes_plan/{docId} {
        allow read: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]))
                     || aUnRole(["superadmin"]);
        allow create: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable"]))
                       || aUnRole(["superadmin"]);
        allow update: if aUnRole(["superadmin"]);
        allow delete: if false;
      }

      match /notesCollege/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "college", "enseignant"]))
                      || aUnRole(["superadmin"]);
      }

      match /notesPrimaire/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "primaire", "enseignant"]))
                      || aUnRole(["superadmin"]);
      }

      match /notesLycee/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "college", "enseignant"]))
                      || aUnRole(["superadmin"]);
      }

      match /absencesCollege/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "college", "enseignant"]))
                      || aUnRole(["superadmin"]);
      }

      match /absencesPrimaire/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "primaire", "enseignant"]))
                      || aUnRole(["superadmin"]);
      }

      match /absencesLycee/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "college", "enseignant"]))
                      || aUnRole(["superadmin"]);
      }

      match /{collection}/{docId} {
        allow read: if appartientEcole(schoolId) || aUnRole(["superadmin"]);
        allow write: if (appartientEcole(schoolId) && aUnRole(["direction", "admin", "comptable", "primaire", "college"]))
                      || aUnRole(["superadmin"]);
      }
    }

    match /ecoles_public/{schoolId} {
      allow read: if true;
      allow write: if false;
    }

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    match /superadmins/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if request.auth != null && aUnRole(["superadmin"]);
    }

    match /transferts/{transfertId} {
      allow read, write: if false;
    }

    match /superadmin_messages/{messageId} {
      allow read: if request.auth != null && roleUtilisateur() != "parent";
      allow create, update, delete: if aUnRole(["superadmin"]);

      match /lectures/{uid} {
        allow read: if aUnRole(["superadmin"])
                     || (request.auth != null && request.auth.uid == uid);
        allow create: if request.auth != null
                       && request.auth.uid == uid
                       && roleUtilisateur() != "parent";
        allow update, delete: if false;
      }
    }

    match /{path=**}/demandes_plan/{docId} {
      allow read: if aUnRole(["superadmin"]);
      allow write: if false;
    }
  }
}
